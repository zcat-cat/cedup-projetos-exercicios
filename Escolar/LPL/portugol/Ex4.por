programa {
  funcao inicio() {
    inteiro distancia, tempo
    real velocidadeMedia

    escreva("Digite a distancia percorrida em km: ")
    leia(distancia)

    escreva("Digite o tempo percorrido em horas: ")
    leia(tempo)

    limpa()

    velocidadeMedia = distancia / tempo
    escreva("\n--------------------------\n")
    escreva("A Velocidade Média  é: ", velocidadeMedia)
    escreva("\n--------------------------\n")




  }
}
